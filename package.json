{
  "name": "@alexus/cli",
  "version": "0.4.0",
  "description": "Secure, provider-independent coding agent CLI powered by OpenRouter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imAlexus/alexus-cli.git"
  },
  "homepage": "https://github.com/imAlexus/alexus-cli#readme",
  "bugs": {
    "url": "https://github.com/imAlexus/alexus-cli/issues"
  },
  "type": "module",
  "bin": {
    "alexus": "./dist/cli.js"
  },
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm build",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "commander": "^14.0.0",
    "cross-spawn": "^7.0.6",
    "diff": "^8.0.2",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "ink": "7.1.0",
    "ink-spinner": "5.0.0",
    "openai": "^5.10.1",
    "picocolors": "^1.1.1",
    "react": "19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cross-spawn": "^6.0.6",
    "@types/diff": "^7.0.2",
    "@types/node": "^24.1.0",
    "@types/react": "19.2.17",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.7.0"
}
